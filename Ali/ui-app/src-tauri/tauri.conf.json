{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ali UI",
  "version": "0.1.0",
  "identifier": "com.ali.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ali",
        "width": 1024,
        "height": 700,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
