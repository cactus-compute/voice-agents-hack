{
  "name": "tsenta-desktop",
  "productName": "Tsenta",
  "version": "3.5.2",
  "minAppVersion": "3.5.0",
  "description": "Tsenta - Automated job application assistant",
  "main": "./dist/main/index.js",
  "scripts": {
    "benchmark:ui": "npx tsx src/benchmark/ui/server.ts",
    "benchmark:ui:dev": "npx tsx src/benchmark/ui/server.ts --dev",
    "benchmark:ui:build": "cd src/benchmark/ui && bun run build",
    "dev": "electron-vite dev",
    "start": "cross-env JAVASCRIPT_OBFUSCATOR_DISABLE_NOTIFICATION=1 electron-vite preview",
    "build": "cross-env JAVASCRIPT_OBFUSCATOR_DISABLE_NOTIFICATION=1 NODE_OPTIONS=--max-old-space-size=16384 node scripts/generate-app-update-yml.mjs && electron-vite build",
    "lint": "npx ultracite lint",
    "format": "npx ultracite format",
    "win:build": "powershell -ExecutionPolicy Bypass -File ./scripts/windows/build-windows.ps1",
    "win:publish": "powershell -ExecutionPolicy Bypass -File ./scripts/windows/publish-windows.ps1",
    "chunks:upload": "node scripts/cloud/upload-github-assets.cjs",
    "chunks:push": "bun run build && node scripts/cloud/prepare-cloud-build.cjs && node scripts/cloud/upload-github-assets.cjs",
    "chunks:test": "npx electron dist/main/index.js",
    "mac:publish": "./scripts/macos/publish-macos.sh",
    "mac:make": "bun run build && npx electron-forge make",
    "mac:dmg": "node scripts/macos/create-dmg.js",
    "package": "bun run build && npx electron-forge package"
  },
  "keywords": [
    "tsenta",
    "automation",
    "job-application",
    "electron"
  ],
  "author": {
    "name": "Agnay Srivastava",
    "email": "srivasa@rose-hulman.edu"
  },
  "license": "UNLICENSED",
  "private": true,
  "trustedDependencies": [
    "@biomejs/biome",
    "@playwright/test",
    "better-sqlite3",
    "electron",
    "electron-winstaller",
    "es5-ext",
    "esbuild",
    "patchright",
    "playwright",
    "protobufjs",
    "sqlite3"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-flatpak": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-electronegativity": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/publisher-github": "^7.10.2",
    "@electron/fuses": "^2.0.0",
    "@reforged/maker-appimage": "^5.1.1",
    "@tsenta/electron-vite-obfuscator": "^2.0.1",
    "electron-vite": "^5.0.0",
    "@types/cheerio": "^1.0.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/lodash": "^4.17.21",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "electron": "39.2.6",
    "typescript": "^5.9.3",
    "ultracite": "^6.4.1"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@playwright/test": "^1.57.0",
    "@sentry/electron": "^7.6.0",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "electron-context-menu": "^4.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.6.2",
    "fuse.js": "^7.1.0",
    "lodash": "^4.17.21",
    "openai": "^6.17.0",
    "patchright": "^1.57.0",
    "playwright": "^1.57.0",
    "rebrowser-playwright": "^1.52.0",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0",
    "zod": "^4.1.13"
  }
}
